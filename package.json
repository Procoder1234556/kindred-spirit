{
  "name": "praiz",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:dev": "nodemon index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:css": "postcss public/styles/tailwind.css -o public/styles/style.css",
    "watch:css": "nodemon -e js,ejs,css -x \"npm run build:css\"",
    "dev": "concurrently \"npm run start:dev\" \"npm run watch:css\"",
    "build": "npm run build:css && npm run build:dist",
    "build:dev": "npm run build:css && npm run build:dist",
    "build:dist": "node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});fs.writeFileSync('dist/index.html','<!doctype html><meta charset=utf-8><title>Sahii</title><p>Server-rendered EJS app. Run npm start.');\""
  },
