# ═══════════════════════════════════════════════════════════════════════════════
# ChainPulse — Environment Variables  (DO NOT COMMIT THIS FILE)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Helius RPC (https://dashboard.helius.xyz) ─────────────────────────────────
HELIUS_API_KEY=70c10370-3968-42fe-80f7-2b8ca198fc53
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=70c10370-3968-42fe-80f7-2b8ca198fc53
HELIUS_WS_URL=wss://atlas-mainnet.helius-rpc.com/?api-key=70c10370-3968-42fe-80f7-2b8ca198fc53

# ── Groq AI  (https://console.groq.com/keys) ──────────────────────────────────
# Model: llama-3.3-70b-versatile  |  Rate limit: 1 call/wallet/5 min
GROQ_API_KEY=your_groq_api_key_here

# ── Telegram Bot  (https://t.me/BotFather → /newbot) ─────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:   redis://localhost:6379
# Upstash: rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── ChainPulse Public API Keys ────────────────────────────────────────────────
# Free tier consumers use this key
CHAINPULSE_FREE_API_KEY=chainpulse_live_test_key
# Pro tier: any key starting with chainpulse_pro_ (generate a strong random suffix)
CHAINPULSE_PRO_API_KEY=chainpulse_pro_your_secret_here

# ── Frontend → Backend URL ───────────────────────────────────────────────────
# Next.js public env — accessible in browser code
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ── Mock Mode ─────────────────────────────────────────────────────────────────
# true  = simulated tx stream (no real Helius key needed)
# false = live Helius WebSocket connection
MOCK_MODE=false

# ── Signal Thresholds ─────────────────────────────────────────────────────────
WHALE_THRESHOLD_SOL=10000
RUG_SCORE_THRESHOLD=75
LIQUIDITY_SHIFT_PCT=20

# ── Optional: Supabase  (https://app.supabase.com) ────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── Optional: MongoDB Atlas ────────────────────────────────────────────────────
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/chainpulse
