            event.preventDefault();
            let prod_input = document.getElementById('s_quantity').value;
            if (Number(prod_input) + 1 > Number(s_quant)) {
                console.log('Single: ', s_quant, ", ", prod_input);
                document.getElementById('s_quantity').value = s_quant - 1;
            }
        }
    </script>
    <!-- Change quantity closed -->

    <!-- Meta Pixel: AddToCart event -->
    <script>
        // Wrap add_to_cart so every call also fires fbq('track', 'AddToCart')
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof add_to_cart === 'function') {
                var _orig_add_to_cart = add_to_cart;
                add_to_cart = function (productId, slug, title, image, quantity, price, sellingPrice, discount, color, token) {
                    // Fire Meta Pixel AddToCart event
                    if (typeof fbq === 'function') {
                        fbq('track', 'AddToCart', {
                            content_ids: [productId],
                            content_name: title,
                            content_type: 'product',
                            value: parseFloat(sellingPrice) || parseFloat(price) || 0,
                            currency: 'INR'
                        });
                    }
                    // Call original function
                    return _orig_add_to_cart.apply(this, arguments);
                };
            }
        });
    </script>
    <!-- End Meta Pixel: AddToCart -->

