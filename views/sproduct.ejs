                                        <script>
                                            function selectVariant(element, colorName, colorHex, actualPrice, stockQuantity, oldPrice) {
                                                // Update selected state visually
                                                document.querySelectorAll('.variant-color-swatch').forEach(el => el.classList.remove('selected'));
                                                if (element) element.classList.add('selected');
                                                
                                                // Update labels
                                                document.getElementById('selected-color-name').textContent = colorName;
                                                document.getElementById('dp-selling-price').textContent = actualPrice;
                                                
                                                // Update cart button
                                                const btn = document.getElementById('btn-add-to-cart');
                                                const maxQuantity = document.getElementById('s_quantity');
                                                const userToken = '<%= user ? user.refreshToken : "-1" %>';
                                                
                                                if (stockQuantity === 0) {
                                                    btn.disabled = true;
                                                    btn.style.opacity = '0.5';
                                                    btn.onclick = null;
                                                    if(maxQuantity) maxQuantity.max = 0;
