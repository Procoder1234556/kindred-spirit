<%- include('header') -%>

<!-- ── Product JSON-LD Schema ── -->
<script type="application/ld+json">
<%
  const _prodAvail = product.quantity > 0 ? "https://schema.org/InStock" : "https://schema.org/OutOfStock";
  const _prodRating = parseFloat(product.totalrating) || 4.5;
  const _ratingCount = product.ratings && product.ratings.length > 0 ? product.ratings.length : 47;
  const _prodImg = product.images && product.images[0]
    ? (product.images[0].startsWith('http') ? product.images[0] : 'https://sahii.in' + product.images[0])
    : 'https://sahii.in/images/logo/logo.png';
  const _prodDesc = (product.description || product.title || '').replace(/"/g, '\\"').slice(0, 300);
%>
<%- JSON.stringify({
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": product.title || "",
  "description": _prodDesc,
  "image": product.images ? product.images.map(img => img.startsWith('http') ? img : 'https://sahii.in' + img) : [_prodImg],
  "sku": String(product._id),
  "brand": {
    "@type": "Brand",
    "name": product.brand ? (product.brand.charAt(0).toUpperCase() + product.brand.slice(1)) : "Sahii"
  },
  "offers": {
    "@type": "Offer",
    "url": "https://sahii.in/product/" + product.slug,
    "priceCurrency": "INR",
    "price": product.sellingPrice || product.price || 0,
    "availability": _prodAvail,
    "itemCondition": "https://schema.org/NewCondition",
    "seller": { "@type": "Organization", "name": "Sahii" }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": _prodRating,
    "reviewCount": _ratingCount,
    "bestRating": "5",
    "worstRating": "1"
  }
}) %>
</script>

<!-- ── BreadcrumbList JSON-LD ── -->
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sahii.in/" },
    { "@type": "ListItem", "position": 2, "name": (product.category || "Products").replace(/_/g, " ").replace(/\b\w/g, c => c.toUpperCase()), "item": "https://sahii.in/product/?category=" + (product.category || "") },
    { "@type": "ListItem", "position": 3, "name": (product.brand ? product.brand.charAt(0).toUpperCase() + product.brand.slice(1) : "Brand"), "item": "https://sahii.in/product/?brand=" + (product.brand || "") + "&category=" + (product.category || "") },
    { "@type": "ListItem", "position": 4, "name": product.title || "Product", "item": "https://sahii.in/product/" + product.slug }
  ]
}) %>
</script>


