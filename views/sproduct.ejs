                                                        display:inline-block; margin-left:8px; font-size:0.75rem;
                                                        padding:2px 8px; border-radius:20px; font-weight:600;
                                                        background:<%= (product.variants[0].stockQuantity||0) > 0 ? '#d1fae5' : '#fee2e2' %>;
                                                        color:<%= (product.variants[0].stockQuantity||0) > 0 ? '#065f46' : '#991b1b' %>;">
                                                        <%= (product.variants[0].stockQuantity||0) > 0 ? 'In Stock' : 'Out of Stock' %>
