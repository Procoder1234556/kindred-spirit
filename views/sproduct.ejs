                                                    btn.setAttribute('onclick', `add_to_cart('<%= product._id %>', '<%= product.slug %>', '<%= product.title %>', '<%= product.images[0] %>', '${stockQuantity}', '${oldPrice}', '${actualPrice}', '<%= product.discount %>', '${colorHex}', '${userToken}')`);
