<%- include('header') -%>

    <section id="reset-password-section" style="margin-top: 150px; margin-bottom: 50px;">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">
                    <div class="card shadow">
                        <div class="card-body p-4 p-lg-5 text-black">
                            
                            <% if (user) { %>
                                <h4 class="mb-4 text-center">Reset Password</h4>
                                <p class="text-center mb-4">For <%= user.email %></p>

                                <form action="/user/setUpdate/<%= user._id %>" method="post" onsubmit="return validatePassword()">
                                    
                                    <div class="form-outline mb-3 pw-field">
                                        <label class="form-label" for="new_pass">New Password</label>
                                        <input type="password" id="new_pass" class="form-control form-control-lg" name="pass" required />
                                        <button type="button" class="pw-eye-btn" onclick="sahiiTogglePw(this)" tabindex="-1" aria-label="Toggle password visibility"><i class="fa-regular fa-eye"></i></button>
                                    </div>

                                    <div class="form-outline mb-3 pw-field">
                                        <label class="form-label" for="confirm_pass">Confirm Password</label>
                                        <input type="password" id="confirm_pass" class="form-control form-control-lg" name="pass" required />
                                        <button type="button" class="pw-eye-btn" onclick="sahiiTogglePw(this)" tabindex="-1" aria-label="Toggle password visibility"><i class="fa-regular fa-eye"></i></button>
                                        <div id="pass_error" style="color: red; display: none; margin-top: 5px;">Passwords do not match</div>
                                    </div>

                                    <div class="d-grid gap-2">
                                        <button style="background-color: #011a3a; color: white;" class="btn btn-lg" type="submit">Update Password</button>
                                    </div>
                                </form>
                            <% } else { %>
                                <div class="alert alert-danger">
                                    User not found or invalid link.
                                </div>
                            <% } %>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        function validatePassword() {
            const passwords = document.getElementsByName('pass');
            if (passwords.length < 2) return false;
            const p1 = passwords[0].value;
            const p2 = passwords[1].value;
            const errorDiv = document.getElementById('pass_error');
            
            if (p1 !== p2) {
                errorDiv.style.display = 'block';
                return false;
            }
            errorDiv.style.display = 'none';
            return true;
        }
    </script>

<%- include('footer') -%>