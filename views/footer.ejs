<!-- Phone Capture Popup -->
<style>
/* Phone Capture Popup Styles */
#lead-capture-modal {
    display: none;
    position: fixed;
    z-index: 10000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
}

.lead-popup-content {
    background-color: #fff;
    padding: 30px;
    border-radius: 12px;
    width: 90%;
    max-width: 400px;
    position: relative;
    text-align: center;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    animation: fadeInScale 0.3s ease-out;
}

@keyframes fadeInScale {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
}

.lead-close-btn {
    position: absolute;
    top: 12px;
    right: 15px;
    font-size: 24px;
    color: #666;
    cursor: pointer;
    background: none;
    border: none;
    line-height: 1;
}

.lead-popup-title {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: #1a1a1a;
}

.lead-popup-desc {
    font-size: 0.95rem;
    color: #555;
    margin-bottom: 20px;
}

.lead-input-group {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.lead-phone-input {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
}

.lead-phone-input:focus {
    border-color: #2563eb;
}

.lead-submit-btn {
    background-color: #2563eb;
    color: #fff;
    border: none;
    padding: 12px;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
}

.lead-submit-btn:hover {
    background-color: #1d4ed8;
}

.lead-success-msg {
    display: none;
    color: #059669;
    background-color: #d1fae5;
    padding: 10px;
    border-radius: 8px;
    margin-top: 15px;
    font-weight: 600;
}
.lead-error-msg {
    color: red;
    font-size: 0.85rem;
    margin-top: -10px;
    margin-bottom: 5px;
    display: none;
    text-align: left;
}
</style>

<div id="lead-capture-modal">
    <div class="lead-popup-content">
        <button class="lead-close-btn" onclick="closeLeadPopup()">&times;</button>
        <h3 class="lead-popup-title">Get exclusive deals!</h3>
        <p class="lead-popup-desc">Enter your phone number for a special coupon code.</p>
        
        <div class="lead-input-group" id="lead-input-group">
            <input type="tel" id="lead-phone" class="lead-phone-input" placeholder="10-digit mobile number" maxlength="10" pattern="[0-9]{10}">
            <div id="lead-error" class="lead-error-msg">Please enter a valid 10-digit Indian number.</div>
            <button class="lead-submit-btn" onclick="submitLeadPhone()">Submit</button>
        </div>
        
        <div id="lead-success" class="lead-success-msg">
            Thank you!
        </div>
    </div>
</div>

<script>
function closeLeadPopup() {
    document.getElementById('lead-capture-modal').style.display = 'none';
    localStorage.setItem('lead_popup_dismissed', 'true');
}

function submitLeadPhone() {
    const phoneInput = document.getElementById('lead-phone');
    const phoneVal = phoneInput.value.trim();
    const errorMsg = document.getElementById('lead-error');
    
    // Indian phone format checking
    if(!/^[6-9]\d{9}$/.test(phoneVal)) {
        errorMsg.style.display = 'block';
        return;
    }
    errorMsg.style.display = 'none';
    
    fetch('/api/capture-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: phoneVal })
    })
    .then(res => res.json())
    .then(data => {
        document.getElementById('lead-input-group').style.display = 'none';
        document.getElementById('lead-success').style.display = 'block';
        localStorage.setItem('lead_popup_dismissed', 'true');
        
        setTimeout(() => {
            closeLeadPopup();
        }, 2000);
    })
    .catch(err => {
        console.error('Error submitting lead:', err);
    });
}

document.addEventListener('DOMContentLoaded', () => {
    if (!localStorage.getItem('lead_popup_dismissed')) {
        setTimeout(() => {
            const modal = document.getElementById('lead-capture-modal');
            if(modal) {
                modal.style.display = 'flex';
            }
        }, 8000);
    }
});
</script>
<!-- End Phone Capture Popup -->

