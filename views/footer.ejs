<!-- Social Proof Toast -->
<style>
.social-proof-toast {
    position: fixed;
    bottom: 30px;
    left: 30px;
    background: #fff;
    padding: 14px 18px;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    display: flex;
    align-items: center;
    gap: 12px;
    z-index: 9998; /* Just behind whatsapp btn if they overlap */
    transform: translateY(100px);
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    max-width: 320px;
    border-left: 4px solid #1a73e8;
    pointer-events: none;
}

.social-proof-toast.show {
    transform: translateY(0);
    opacity: 1;
}

.sp-icon {
    font-size: 1.4rem;
    line-height: 1;
}

.sp-text {
    font-size: 0.85rem;
    color: #333;
    line-height: 1.4;
    margin: 0;
}

@media (max-width: 768px) {
    .social-proof-toast {
        left: 20px;
        bottom: 90px; /* Position above mobile whatsapp float btn */
        padding: 12px 14px;
        max-width: 280px;
    }
}
</style>

<div class="social-proof-toast" id="social-proof-toast">
    <div class="sp-icon" id="sp-icon"></div>
    <p class="sp-text" id="sp-text"></p>
</div>

<script>
(function() {
    const hideOnPaths = ['/cart', '/checkout', '/thankyou'];
    const currentPath = window.location.pathname.toLowerCase();
    
    // Don't run social proof on cart/checkout
    if (hideOnPaths.some(p => currentPath.includes(p))) {
        return;
    }

    const names = ["Rahul", "Priya", "Amit", "Sneha", "Vikram", "Rohan", "Anjali", "Karan", "Pooja", "Arjun", "Neha", "Aditya", "Riya", "Suresh", "Ramesh", "Deepak", "Sunita", "Manoj", "Kiran", "Vijay", "Aakash", "Meera"];
    const cities = ["Delhi", "Mumbai", "Bangalore", "Pune", "Chennai", "Kolkata", "Hyderabad", "Ahmedabad", "Surat", "Jaipur", "Lucknow", "Gurgaon", "Noida", "Bhopal", "Indore", "Chandigarh"];
    const products = ["iPhone 13 Display", "Samsung A52 Battery", "OnePlus 9 Pro Back Cover", "Redmi Note 10 Charging PCB", "Realme 8 Camera Lens", "Vivo V21 Display", "Oppo F19 Pro Battery", "Poco X3 Glass", "iPhone 11 Battery", "Samsung M31 Screen", "OnePlus Nord Display", "Redmi 9 Power Battery"];
    
    const toast = document.getElementById('social-proof-toast');
    const iconEl = document.getElementById('sp-icon');
    const textEl = document.getElementById('sp-text');

    if (!toast) return;

    function getRandomItem(arr) {
        return arr[Math.floor(Math.random() * arr.length)];
    }

    function showToast() {
        const type = Math.floor(Math.random() * 3);
        let icon, text;
        const logoImg = '<img src="/images/logo/logo.png" style="width: 32px; height: 32px; object-fit: contain; margin-right: 10px;">';

        if (type === 0) {
            icon = logoImg;
            text = `<strong>${getRandomItem(names)}</strong> from ${getRandomItem(cities)} just ordered <strong>${getRandomItem(products)}</strong>`;
        } else if (type === 1) {
            icon = logoImg;
            const viewing = Math.floor(Math.random() * 25) + 12;
            text = `<strong>${viewing} people</strong> are viewing this product`;
        } else {
            icon = logoImg;
            const mins = Math.floor(Math.random() * 59) + 1;
            text = `<strong>${getRandomItem(names)}</strong> from ${getRandomItem(cities)} purchased <strong>${getRandomItem(products)}</strong> ${mins} mins ago`;
        }

        iconEl.innerHTML = icon;
        textEl.innerHTML = text;
        toast.classList.add('show');

        // Hide after 4 seconds
        setTimeout(() => {
            toast.classList.remove('show');
            scheduleNext();
        }, 4000);
    }

    function scheduleNext() {
        // Random interval between 8 to 12 seconds
        const nextIn = Math.floor(Math.random() * 4000) + 8000;
        setTimeout(showToast, nextIn);
    }

    // Start the first one after 3.5 seconds
    setTimeout(showToast, 3500);
})();
</script>
<!-- End Social Proof Toast -->

