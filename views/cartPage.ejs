<%- include('header') -%>

<section id="sahii-cart">
    <div class="sahii-cart-wrap container">

        <% if (!Cart || !Cart.products || Cart.products.length === 0) { %>

        <!-- ── EMPTY STATE ── -->
        <div class="sahii-cart-empty">
            <div class="sahii-cart-empty-icon">
                <i class="fa-solid fa-cart-shopping"></i>
            </div>
            <h2 class="sahii-cart-empty-title">Your Cart is Empty</h2>
            <p class="sahii-cart-empty-sub">Looks like you haven't added anything yet. Let's fix that!</p>
            <a href="/product" class="sahii-cart-explore-btn">Explore Products</a>
        </div>

        <% } else { %>

        <!-- ── CART HEADER ── -->
        <div class="sahii-cart-header">
            <h1 class="sahii-cart-title">
                <i class="fa-solid fa-cart-shopping me-2"></i>Shopping Cart
                <span class="sahii-cart-count"><%= Cart.products.length %> item<%= Cart.products.length !== 1 ? 's' : '' %></span>
            </h1>
            <a href="/product" class="sahii-continue-link"><i class="fa-solid fa-arrow-left me-1"></i>Continue Shopping</a>
        </div>

        <!-- ── FREE DELIVERY BANNER ── -->
        <% var remaining = 599 - (Cart.cartTotal - Cart.couponDiscount); %>
        <% if (remaining > 0) { %>
        <div class="sahii-free-ship-bar">
            <i class="fa-solid fa-truck-fast me-2"></i>
            Add <strong>₹<%= remaining.toFixed(0) %></strong> more to get <strong>FREE delivery</strong>!
            <div class="sahii-ship-progress">
                <div class="sahii-ship-fill" style="width: <%= Math.min(((Cart.cartTotal - Cart.couponDiscount) / 599) * 100, 100) %>%"></div>
            </div>
        </div>
        <% } else { %>
        <div class="sahii-free-ship-bar sahii-free-ship-active">
            <i class="fa-solid fa-circle-check me-2"></i>
            You've unlocked <strong>FREE delivery</strong>!
        </div>
        <% } %>

        <!-- ── MAIN GRID ── -->
        <div class="sahii-cart-grid">

            <!-- LEFT: Product list -->
            <div class="sahii-cart-items">
                <% Cart.products.forEach(item => { %>
                <div class="sahii-cart-item" data-cart-prod-id="<%= item._id %>">
                    <!-- Product image -->
                    <a href="/product/<%= item?.title?.toLowerCase()?.replaceAll(' ','-') %>" class="sahii-item-img-wrap">
                        <img src="<%= item?.image %>" alt="<%= item.title %>" class="sahii-item-img" loading="lazy">
                    </a>

                    <!-- Product info -->
                    <div class="sahii-item-info">
                        <a href="/product/<%= item?.title?.toLowerCase()?.replaceAll(' ','-') %>" class="sahii-item-name"><%= item.title %></a>
                        <% if (item.color) { %>
                        <div class="sahii-item-meta">Colour: <span><%= item.color %></span></div>
                        <% } %>
                        <div class="sahii-item-price">₹<%= item.sellingPrice %></div>

                        <!-- Qty + actions row -->
                        <div class="sahii-item-actions">
                            <div class="sahii-qty">
                                <% if (item.sellingPrice === 0) { %>
                                    <button class="sahii-qty-btn" disabled>−</button>
                                    <input class="sahii-qty-input" type="text" value="<%= item.count %>" readonly>
                                    <button class="sahii-qty-btn" disabled>+</button>
                                <% } else { %>
                                    <a class="sahii-qty-btn" href="" onclick="event.preventDefault(); toggle_quantity('<%= Cart._id %>', '<%= item._id %>', -1)">−</a>
                                    <input class="sahii-qty-input" type="text" data-prod-id="<%= item._id %>" value="<%= item.count %>">
                                    <a class="sahii-qty-btn" href="" onclick="event.preventDefault(); toggle_quantity('<%= Cart._id %>', '<%= item._id %>', 1)">+</a>
                                    <div class="spinner"></div>
                                <% } %>
                            </div>
                            <button class="sahii-item-wishlist" onclick="add_to_wishlist('<%= item._id %>', '<%= Cart.orderby %>')">
                                <i class="fa-regular fa-heart"></i> Wishlist
                            </button>
                            <button class="sahii-item-remove remove_cart" onclick="remove_from_cart('<%= item._id %>', '<%= bearerToken %>')">
                                <i class="fa-solid fa-trash-can"></i> Remove
                            </button>
                        </div>
                    </div>

                    <!-- Item subtotal -->
                    <div class="sahii-item-subtotal">₹<%= (item.sellingPrice * item.count).toFixed(0) %></div>
                </div>
                <% }) %>
            </div>

            <!-- RIGHT: Order summary -->
            <aside class="sahii-cart-summary">
                <h2 class="sahii-summary-title">Order Summary</h2>

                <!-- Coupon -->
                <div class="sahii-coupon-row">
                    <button class="sahii-avail-coupon-btn" onclick="openCouponModal()">
                        <i class="fa-solid fa-tag me-1"></i>Avail Coupon
                    </button>
                </div>
                <div class="sahii-coupon-input-row">
                    <input type="text" name="coupon-code" id="couponName1" class="sahii-coupon-input" placeholder="Enter coupon code">
                    <button class="sahii-apply-btn" onclick="applyCoupon('<%= user._id %>')">Apply</button>
                    <% if (Cart.couponDiscount > 0) { %>
                    <button class="sahii-remove-coupon" onclick="removeCoupon('<%= user._id %>')">✕</button>
                    <% } %>
                </div>
                <div class="alert alert-success sahii-alert" role="alert">Coupon <b>accepted!</b></div>
                <div class="alert alert-danger sahii-alert" role="alert">Coupon <b>rejected!</b></div>

                <!-- Breakdown -->
                <div class="sahii-summary-lines">
                    <div class="sahii-summary-line">
                        <span>Product Total</span>
                        <span>₹<%= Cart.totalAmount %></span>
                    </div>
                    <div class="sahii-summary-line sahii-saving">
                        <span>Product Discount</span>
                        <span>− ₹<%= Cart.totalAmount - Cart.cartTotal %></span>
                    </div>
                    <% if (Cart.couponDiscount > 0) { %>
                    <div class="sahii-summary-line sahii-saving">
                        <span>Coupon Discount</span>
                        <span>− ₹<%= Cart.couponDiscount %></span>
                    </div>
                    <% } %>
                    <div class="sahii-summary-line">
                        <span>Delivery</span>
                        <% if (Cart.cartTotal - Cart.couponDiscount >= 599) { %>
                            <span class="sahii-free-label"><del class="text-muted me-1" style="font-size:.8rem;">₹<%= Cart.deliveryCharge %></del>FREE</span>
                        <% } else { %>
                            <span>₹<%= Cart.deliveryCharge %></span>
                        <% } %>
                    </div>
                </div>

                <!-- Total -->
                <div class="sahii-summary-total">
                    <span>Total</span>
                    <span class="sahii-total-amt">
                        ₹<%= (Cart.cartTotal + (Cart.cartTotal - Cart.couponDiscount >= 599 ? 0 : Cart.deliveryCharge) - Cart.couponDiscount).toFixed(0) %>
                    </span>
                </div>
                <p class="sahii-tax-note">*Inclusive of all taxes</p>

                <!-- Checkout -->
                <% if (Cart.cartTotal > 0) { %>
                    <button class="sahii-checkout-btn cart_checkout" onclick="checkout('<%= Cart._id %>', '<%= user._id %>')">
                        <i class="fa-solid fa-lock me-2"></i>Proceed to Checkout
                    </button>
                <% } else { %>
                    <button class="sahii-checkout-btn disabled" disabled>
                        <i class="fa-solid fa-lock me-2"></i>Proceed to Checkout
                    </button>
                <% } %>
                <a href="/" class="sahii-continue-btn">Continue Shopping</a>
            </aside>

        </div><!-- /sahii-cart-grid -->
        <% } %>
    </div><!-- /sahii-cart-wrap -->
</section>

<!-- Coupon Modal -->
<div id="couponModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeCouponModal()">&times;</span>
        <h5 style="margin-bottom: 1rem;">Available Coupons</h5>
        <div id="couponList" style="max-height: 300px; overflow-y: auto; text-align: left;"></div>
    </div>
</div>

<!-- Hidden coupon input for mobile compat -->
<input type="hidden" id="couponName2" value="">

<script>
    window.CART_USER_ID = "<%= user ? user._id : '' %>";
</script>

<%- include('footer') -%>
