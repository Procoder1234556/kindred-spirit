            <!-- ── FAQPage JSON-LD Schema ── -->
            <script type="application/ld+json">
            {
              "@context": "https://schema.org",
              "@type": "FAQPage",
              "mainEntity": [
                {
                  "@type": "Question",
                  "name": "How do I replace a cracked phone screen at home?",
                  "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "To replace a cracked phone screen at home, you need the correct OEM-grade display assembly for your model, a repair toolkit (spudger, screwdrivers, suction cup), and careful step-by-step guidance. Sahii provides all these parts and tools. We recommend watching a model-specific repair video before starting. Always power off the device, remove the SIM tray, and heat the adhesive edges before prying open the frame."
                  }
                },
                {
                  "@type": "Question",
                  "name": "What is an OEM-grade spare part?",
                  "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "OEM-grade (Original Equipment Manufacturer-grade) spare parts are replacement components manufactured to the same quality standards and specifications as the original parts that come with your device. They offer the best fit, finish, and performance compared to aftermarket alternatives. Sahii sells OEM-grade displays, batteries, back panels, and more for Samsung, Apple, Xiaomi, OnePlus, and other major brands."
                  }
                },
                {
                  "@type": "Question",
                  "name": "How long does delivery take for spare parts ordered on Sahii?",
                  "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Sahii typically delivers spare parts within 3–7 business days across India. Metro cities usually receive orders faster (2–4 days). All orders are shipped securely with bubble wrap and protective packaging to ensure parts arrive undamaged. You can track your order after dispatch."
                  }
                },
                {
                  "@type": "Question",
                  "name": "Are the spare parts on Sahii compatible with my specific phone model?",
                  "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Yes. Every product on Sahii is listed with the exact compatible brand and model (e.g., Samsung Galaxy S23 Ultra, iPhone 13 Pro Max). Simply browse by brand, select your model, and choose the part you need. If you are unsure, use the search bar or contact our support team. We verify compatibility before listing any product."
                  }
                },
                {
                  "@type": "Question",
                  "name": "What is the return and replacement policy for spare parts on Sahii?",
                  "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Sahii offers a replacement policy for parts that arrive physically damaged or with missing components. To initiate a replacement, contact us within 48 hours of receiving the order with photos of the damaged item. We review each case and arrange a pickup and replacement. Please refer to our Return Policy page for full terms and conditions."
                  }
                }
              ]
            }
            </script>

