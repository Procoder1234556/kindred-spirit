<!DOCTYPE html>
<html lang="en">
<%- include('partials/admin_head') %>

  <body>
    <%- include('partials/admin_sidebar') %>

      <section id="content">
        <div class="container-fluid mt-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
              <h2 class="mb-0">Sahii Admin Dashboard</h2>
              <p class="text-muted mb-0" style="font-size:0.9rem;">
                Quick overview of key areas. Use the left sidebar for full tools.
              </p>
            </div>
            <span class="badge bg-primary">Admin</span>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                  <h5 class="card-title mb-1">Products</h5>
                  <p class="text-muted" style="font-size:0.85rem;">Manage catalog, images and styles.</p>
                  <button class="btn btn-sm btn-outline-primary" onclick="window.location.href='/product'">
                    View all products
                  </button>
                </div>
              </div>
            </div>

            <div class="col-md-4">
              <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                  <h5 class="card-title mb-1">Orders</h5>
                  <p class="text-muted" style="font-size:0.85rem;">Track and update customer orders.</p>
                  <button class="btn btn-sm btn-outline-primary" onclick="openRoute('getOrders')">
                    Go to orders
                  </button>
                </div>
              </div>
            </div>

            <div class="col-md-4">
              <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                  <h5 class="card-title mb-1">Coupons</h5>
                  <p class="text-muted" style="font-size:0.85rem;">Configure offers, discounts and rules.</p>
                  <button class="btn btn-sm btn-outline-primary me-2" onclick="openRoute('getAllCoupon')">
                    Coupons
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                  <h5 class="card-title mb-1">Analytics Dashboard</h5>
                  <p class="text-muted" style="font-size:0.85rem;">
                    Open the Sahii Admin Analytics dashboard powered by GA4 and Looker Studio.
                  </p>
                  <button class="btn btn-sm btn-outline-secondary" onclick="openRoute('analytics')">
                    Open Dashboard
                  </button>
                </div>
              </div>
            </div>

            <div class="col-md-4">
              <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                  <h5 class="card-title mb-2">Getting started</h5>
                  <ul class="mb-0" style="font-size:0.85rem;">
                    <li>Use <strong>Add Product</strong> to onboard new items.</li>
                    <li>Mark key products on <strong>Sale</strong> from the sidebar.</li>
                    <li>Use <strong>Coupon</strong> to create min/max order value offers.</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="col-md-6 mt-2">
              <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                  <h5 class="card-title mb-2">Shortcuts</h5>
                  <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-sm btn-outline-dark" onclick="openRoute('addProduct')">Add Product</button>
                    <button class="btn btn-sm btn-outline-dark" onclick="openRoute('userTracking')">All Users</button>
                    <button class="btn btn-sm btn-outline-dark" onclick="openRoute('productTracking')">Product Tracking</button>
                    <button class="btn btn-sm btn-outline-dark" onclick="openRoute('createCoupon')">Create Coupon</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Content dynamically swapped by admin.js for specific tools -->
        <div id="coupons-container" style="display:none;"></div>
      </section>
      <script>
        // Expose Looker Studio URL (if set) to client-side admin JS
        window.LOOKER_STUDIO_URL = "<%= process.env.LOOKER_STUDIO_URL || '' %>";
      </script>
      <script src="/js/admin.js?v=<%= Date.now() %>"></script>
      <script>
        function openMarkSale() {
            const container = document.getElementById("content");
            container.innerHTML = `
                <div class="container mt-5">
                    <h2>Mark Product for Sale</h2>
                    <div class="mb-3">
                        <label for="saleProductSlug" class="form-label">Product Slug</label>
                        <input type="text" class="form-control" id="saleProductSlug" placeholder="Enter product slug (e.g. some-product-name)">
                    </div>
                    <button class="btn btn-primary" onclick="submitMarkSale()">Mark as Sale</button>
                    <div id="saleMessage" class="mt-3"></div>
                </div>
            `;
        }

        async function submitMarkSale() {
            const slug = document.getElementById("saleProductSlug").value;
            const msgDiv = document.getElementById("saleMessage");
            
            if (!slug) {
                msgDiv.innerHTML = '<div class="alert alert-danger">Please enter a slug</div>';
                return;
            }

            try {
                const response = await fetch('/product/mark-sale', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ slug: slug })
                });
                
                const data = await response.json();
                
                if (response.ok) {
                    msgDiv.innerHTML = `<div class="alert alert-success">Success! Product "${data.title}" marked as sale.</div>`;
                } else {
                    msgDiv.innerHTML = `<div class="alert alert-danger">Error: ${data.message}</div>`;
                }
            } catch (error) {
                console.error(error);
                msgDiv.innerHTML = '<div class="alert alert-danger">Something went wrong.</div>';
            }
        }

        // Custom Update Images Implementation (Bypassing admin.js)
        function openUpdateImagesCustom() {
            const container = document.getElementById("content");
            container.innerHTML = `
                <div class="container mt-5">
                    <h2>Update Product Images</h2>
                    <div class="mb-3">
                        <label class="form-label">Product Slug</label>
                        <input type="text" class="form-control" id="updateImgSlug" placeholder="Enter Product Slug">
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Thumbnail (Single Image)</label>
                        <input type="file" class="form-control" id="updateThumbnail" name="thumbnail" accept="image/*">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Gallery Images (Multiple)</label>
                        <input type="file" class="form-control" id="updateImagesInput" name="images" multiple accept="image/*">
                        <small class="text-muted">Note: This will replace the existing gallery.</small>
                    </div>

                    <button class="btn btn-primary" onclick="submitUpdateImagesCustom()">Update Images</button>
                    <div id="updateImgMessage" class="mt-3"></div>
                </div>
            `;
        }

        async function submitUpdateImagesCustom() {
            const slug = document.getElementById("updateImgSlug").value;
            const thumbnailInput = document.getElementById("updateThumbnail");
            const imagesInput = document.getElementById("updateImagesInput");
            const msgDiv = document.getElementById("updateImgMessage");
            
            if(!slug) {
                msgDiv.innerHTML = '<div class="alert alert-danger">Please enter a slug</div>';
                return;
            }

            const formData = new FormData();
            formData.append("slug", slug);

            if (thumbnailInput.files.length > 0) {
                formData.append("thumbnail", thumbnailInput.files[0]);
            }

            if (imagesInput.files.length > 0) {
                for (let i = 0; i < imagesInput.files.length; i++) {
                    formData.append("images", imagesInput.files[i]);
                }
            }

            msgDiv.innerHTML = '<div class="alert alert-info">Uploading...</div>';

            try {
                const response = await fetch("/product/updateImages", {
                    method: "POST",
                    body: formData
                });
                
                const data = await response.json();
                if (response.ok) {
                    msgDiv.innerHTML = `<div class="alert alert-success">Success! Images updated for ${slug}</div>`;
                    console.log(data);
                } else {
                    msgDiv.innerHTML = `<div class="alert alert-danger">Error: ${data.message || "Unknown error"}</div>`;
                }
            } catch (error) {
                console.error("Error:", error);
                msgDiv.innerHTML = `<div class="alert alert-danger">Something went wrong: ${error.message}</div>`;
            }
        }
      </script>
  </body>

</html>