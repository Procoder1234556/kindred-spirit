        </div>
        <!-- Pagination -->
        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div class="pagination-container" style="display: flex; justify-content: center; margin: 2rem 0; gap: 0.5rem; flex-wrap: wrap; font-size: 0.9rem;">
                        <% if (currentPage > 1) { %>
                            <button class="btn btn-outline-primary btn-sm" style="border-radius: 2px;" onclick="changePage(<%= currentPage - 1 %>)">Prev</button>
                        <% } %>

                        <% 
                           let startPage = Math.max(1, currentPage - 2);
                           let endPage = Math.min(totalPages, currentPage + 2);

                           if (startPage > 1) { %>
                               <button class="btn btn-outline-primary btn-sm" style="border-radius: 2px;" onclick="changePage(1)">1</button>
                               <% if (startPage > 2) { %> <span style="align-self: center;">...</span> <% } %>
                           <% }

                           for(let i = startPage; i <= endPage; i++) { 
                        %>
                            <button class="btn <%= currentPage === i ? 'btn-primary' : 'btn-outline-primary' %> btn-sm" 
                                    style="border-radius: 2px;" 
                                    onclick="changePage(<%= i %>)">
                                <%= i %>
                            </button>
                        <% } 

                           if (endPage < totalPages) { %>
                               <% if (endPage < totalPages - 1) { %> <span style="align-self: center;">...</span> <% } %>
                               <button class="btn btn-outline-primary btn-sm" style="border-radius: 2px;" onclick="changePage(<%= totalPages %>)"><%= totalPages %></button>
                           <% }
                        %>

                        <% if (currentPage < totalPages) { %>
                            <button class="btn btn-outline-primary btn-sm" style="border-radius: 2px;" onclick="changePage(<%= currentPage + 1 %>)">Next</button>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
        
        <script>
            function changePage(page) {
                const url = new URL(window.location.href);
                url.searchParams.set('page', page);
                window.location.href = url.toString();
            }
        </script>
        <% } %>

        <!-- ── Contextual Parts Search JS ─────────────────────────────────── -->
        <script>
        (function () {
            const input      = document.getElementById('parts-search-input');
            const clearBtn   = document.getElementById('parts-search-clear');
            const countEl    = document.getElementById('parts-search-count');
            const noResults  = document.getElementById('parts-no-results');
            const termEl     = document.getElementById('parts-no-results-term');
            const cards      = document.querySelectorAll('.product-card-col');

            // Only wire up if the search bar exists on this page
            if (!input) return;

            function filterParts() {
                const q = input.value.trim().toLowerCase();

                // Show / hide clear button
                if (clearBtn) clearBtn.style.display = q ? 'inline' : 'none';

                let visibleCount = 0;

                cards.forEach(function (col) {
                    const name = col.getAttribute('data-product-name') || '';
                    const show = q === '' || name.includes(q);
                    col.style.display = show ? '' : 'none';
                    if (show) visibleCount++;
                });

                // Update result count hint
                if (countEl) {
                    if (q === '') {
                        countEl.textContent = '';
                    } else {
                        countEl.textContent = visibleCount + ' part' + (visibleCount !== 1 ? 's' : '') + ' found';
                    }
                }

                // No-results empty state
                if (noResults) {
                    if (visibleCount === 0 && q !== '') {
                        noResults.style.display = 'block';
                        if (termEl) termEl.textContent = input.value.trim();
                    } else {
                        noResults.style.display = 'none';
                    }
                }
            }

            // Debounce for a snappy feel without firing on every keystroke
            let debounceTimer;
            input.addEventListener('input', function () {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(filterParts, 160);
            });

            // Clear button
            if (clearBtn) {
                clearBtn.addEventListener('click', function () {
                    input.value = '';
                    filterParts();
                    input.focus();
                });
            }

            // Auto-focus the bar when the page has a model param
            // (the bar is only rendered when queryParams.model is set)
            input.addEventListener('focus', function () {
                this.parentElement.style.borderColor = '#1a73e8';
            });
            input.addEventListener('blur', function () {
                this.parentElement.style.borderColor = '#c7d8f5';
            });
        })();
        </script>

