    <script>
    // ── Filter sidebar toggle ──────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        const sidebar    = document.getElementById('filterSidebar');
        const openBtn    = document.querySelector('.filter-mob');
        const closeBtn   = document.getElementById('closeSideMenu');

        if (openBtn && sidebar) {
            openBtn.addEventListener('click', (e) => {
                e.preventDefault();
                sidebar.classList.add('active');
                sidebar.style.left = '0';
            });
        }
        if (closeBtn && sidebar) {
            closeBtn.addEventListener('click', () => {
                sidebar.classList.remove('active');
                sidebar.style.left = '-100%';
            });
        }

        // ── Dropdown section toggles ───────────────────────────────────────────
        document.querySelectorAll('.dropdown-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                this.classList.toggle('active');
                const content = this.nextElementSibling;
                if (content) content.style.display = content.style.display === 'none' ? 'block' : 'none';
            });
        });

        // ── Dual price range slider ────────────────────────────────────────────
        const rangeMin    = document.getElementById('rangeMin');
        const rangeMax    = document.getElementById('rangeMax');
        const minInput    = document.getElementById('minPriceInput');
        const maxInput    = document.getElementById('maxPriceInput');
        const minLabel    = document.getElementById('minLabel');
        const maxLabel    = document.getElementById('maxLabel');
        const priceTrack  = document.getElementById('priceTrack');

        function updateTrack() {
            const min = parseInt(rangeMin.value);
            const max = parseInt(rangeMax.value);
            const pct1 = (min / 10000) * 100;
            const pct2 = (max / 10000) * 100;
            if (priceTrack) {
                priceTrack.style.left  = pct1 + '%';
                priceTrack.style.width = (pct2 - pct1) + '%';
            }
            if (minLabel) minLabel.textContent = min;
            if (maxLabel) maxLabel.textContent = max;
            if (minInput) minInput.value = min;
            if (maxInput) maxInput.value = max;
        }

        if (rangeMin && rangeMax) {
            rangeMin.addEventListener('input', () => {
                if (parseInt(rangeMin.value) > parseInt(rangeMax.value))
                    rangeMin.value = rangeMax.value;
                updateTrack();
            });
            rangeMax.addEventListener('input', () => {
                if (parseInt(rangeMax.value) < parseInt(rangeMin.value))
                    rangeMax.value = rangeMin.value;
                updateTrack();
            });
            if (minInput) minInput.addEventListener('input', () => { rangeMin.value = minInput.value; updateTrack(); });
            if (maxInput) maxInput.addEventListener('input', () => { rangeMax.value = maxInput.value; updateTrack(); });
            updateTrack(); // initialise on load
        }

        // ── Sort mobile panel ──────────────────────────────────────────────────
        const sortBtn      = document.querySelector('.sort-mob');
        const sortMenu     = document.querySelector('.mid-option');
        const closeSortBtn = document.querySelector('.close-mid-menu');
        if (sortBtn && sortMenu) {
            sortBtn.addEventListener('click', (e) => {
                e.preventDefault();
                sortMenu.classList.add('active');
                sortMenu.style.bottom  = '0';
                sortMenu.style.display = 'block';
            });
        }
        if (closeSortBtn && sortMenu) {
            closeSortBtn.addEventListener('click', () => {
                sortMenu.classList.remove('active');
                sortMenu.style.bottom = '-100%';
            });
        }

        // ── Style/Sort dropdowns in listing area ───────────────────────────────
        document.querySelectorAll('.style-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const content = this.nextElementSibling;
                if (content) content.style.display = content.style.display === 'block' ? 'none' : 'block';
            });
        });
    });
    </script>

