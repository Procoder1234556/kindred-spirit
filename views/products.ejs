<%- include('header') -%>

<!-- ── BreadcrumbList JSON-LD ── -->
<script type="application/ld+json">
<%
  const _urlParams = new URLSearchParams
    ? (typeof URLSearchParams !== 'undefined' ? null : null)
    : null;
  const _bCat  = typeof Products !== 'undefined' && Products.length > 0 && Products[0].category ? Products[0].category : '';
  const _bBrand = typeof Products !== 'undefined' && Products.length > 0 && Products[0].brand   ? Products[0].brand   : '';
  const _bcItems = [
    { "@type": "ListItem", "position": 1, "name": "Home",     "item": "https://sahii.in/"      },
    { "@type": "ListItem", "position": 2, "name": "Products", "item": "https://sahii.in/product/" }
  ];
  if (_bCat)   _bcItems.push({ "@type": "ListItem", "position": 3, "name": _bCat.replace(/_/g,' ').replace(/\b\w/g, c=>c.toUpperCase()),    "item": "https://sahii.in/product/?category=" + _bCat });
  if (_bBrand) _bcItems.push({ "@type": "ListItem", "position": _bcItems.length + 1, "name": _bBrand.charAt(0).toUpperCase() + _bBrand.slice(1), "item": "https://sahii.in/product/?brand=" + _bBrand + (_bCat ? "&category=" + _bCat : "") });
%>
<%- JSON.stringify({ "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": _bcItems }) %>
</script>




