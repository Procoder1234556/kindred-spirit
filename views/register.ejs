                                        </div>
                                    </div>

                                    <a class="small text-muted" href="/user/forgotPass">Forgot password?</a>
                                    <p class="pb-lg-2" style="color: #393f81;">Don't have an account?
                                        <a class="reg-here" style="color: #393f81; cursor: pointer;">Register
                                            here</a>
                                    </p>
                                    <a id="login-email-link" class="login-number" style="cursor: pointer; font-size: 1rem; color: #132043; font-weight: bold; text-decoration: underline;">Sign in</a>
                                    </form>
                                </div>
                                <!-- Login mob_no end -->

                                        <!-- Register start -->

                                        <div class="register-form">
                                        <form action="/user/register" method="post">

