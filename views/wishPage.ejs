<%- include('header') -%>


    <!-- Top Banner -->
    <div class="top-banner" style="margin-top: 15rem;">
        <div class="product-top-banner-wish"></div>
    </div>

    <!-- Mobile View Buttons -->
    <section id="mob-cart-view">

        <div class="mob-cart-page container d-block d-sm-none">
            <h5 class="text-center">Wishlist</h5>

            <h5 class="text-center">Wishlist</h5>

            <% if(!Wishlist || Wishlist.length === 0) { %>
                <div style="text-align: center; padding: 3rem 1rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24" stroke="#cfd8dc" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                    </svg>
                    <h6 style="color: #607d8b; margin-top: 1rem;">Your wishlist is empty</h6>
                </div>
            <% } else { %>
                <% Wishlist.forEach(item=> { %>

                    <div class="product-card" data-wishlist-product="<%= item._id %>">
                        <div class="card">
                            <a href="/product/<%= item.slug %>">
                                <div class="card-left">
                                    <img src="<%= item.images[0] %>" class="card-img-top" alt="product-img" loading="lazy">
                                </div>
                            </a>
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%= item.title %>
                                </h5>
                                <div style="display: flex;">

                                    <button type="button" class="btn btn-outline-light"
                                        onclick="remove_from_wishlist('<%= item._id %>', '<%= user._id %>')"><i
                                            class="fa-solid fa-trash" style="color: #000000;"></i>Remove
                                    </button>

                                    <div class="py-1">
                                        <% 
                                        const ratingNumWish = parseFloat(item.totalrating) || 4.0;
                                        for(let i=1; i<=5; i++) { 
                                            if(ratingNumWish >= i) { %>
                                                <i class="fa-solid fa-star" style="color: #FFD43B;"></i>
                                            <% } else if(ratingNumWish >= i - 0.5) { %>
                                                <i class="fa-solid fa-star-half-stroke" style="color: #FFD43B;"></i>
                                            <% } else { %>
                                                <i class="fa-regular fa-star" style="color: #FFD43B;"></i>
                                        <% } } %>
                                        <span style="font-size: 0.8em; color: #777;">(<%= item.reviewCount || Math.floor(Math.random()*(180-12+1))+12 %>)</span>
                                    </div>

                                </div>
                                <div id="p-cost" style="line-height: normal;">
                                    <h6>&#8377; <%= item.sellingPrice %>
                                    </h6>
                                </div>
                                <div id="p-color" style="line-height: normal;">
                                    <%= item.color %>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% })} %>
        </div>
    </section>

    <section id="cart-page">
        <div class="cart-page-inner container d-none d-sm-flex">
            <div class="cart-page-left">
                <h5 class="section-head fw-bold">WishList</h5>
                <table class="table">
                    <thead>
                        <tr>
                            <th scope="col">Product</th>
                            <th scope="col" class="color-head">Colour</th>
                            <th scope="col" class="price-head">Price</th>
                        </tr>
                    </thead>
                    <tbody>

                        <% if(!Wishlist || Wishlist.length === 0) { %>
                            <tr>
                                <td colspan="3" style="text-align: center; padding: 4rem 1rem;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="none" viewBox="0 0 24 24" stroke="#cfd8dc" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                                    </svg>
                                    <h5 style="color: #607d8b; margin-top: 1.5rem;">Your wishlist is empty</h5>
                                </td>
                            </tr>
                        <% } else { %>
                            <% Wishlist.forEach(item=> { %>
                                <tr data-wishlist-product="<%= item._id %>">
                                    <td class="product-col">
                                        <div class="product-card">
                                            <div class="card" style="width: 18rem;">
                                                <img src="<%= item.images[0] %>" class="card-img-top" alt="product" loading="lazy">
                                                <div class="card-body">
                                                    <a href="/product/<%= item.slug %>">
                                                        <h5 class="card-title">
                                                            <%= item.title %>
                                                        </h5>
                                                    </a>
                                                    <div class="card-btn">

                                                        <button type="button" class="btn btn-outline-light"
                                                            onclick="remove_from_wishlist('<%= item._id %>', '<%= user._id %>')"><i
                                                                class="fa-solid fa-trash"
                                                                style="color: #000000;"></i>Remove
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="color-col">
                                        <%= item.color %>
                                    </td>
                                    <td class="price-col">&#8377; <%= item.sellingPrice %>
                                    </td>
                                </tr>
                                <% })} %>

                    </tbody>
                </table>
            </div>

        </div>
    </section>


    <!-- Footer -->
    <%- include('footer') -%>