</head>

<body data-bs-spy="scroll" data-bs-target=".navbar">

    <!-- Top Messege bar -->
    <!--Navigation Section-->
    <section id="header">

        <div class="top-bar d-none d-lg-flex" style="position: absolute;">
            <div class="announcement-bar">
                Free delivery across India
            </div>

        </div>
        
        <nav class="navbar navbar-expand-lg fixed-top expanded">

            <div class="top-bar d-md-flex d-lg-none">
                <div class="announcement-bar">
                    Free delivery across India
                </div>
    
            </div>

            <div class="container">
                <a class="navbar-brand" href="/">
                    <img src="/images/logo/logo.png" class="brand-logo img-fluid">
                </a>

                <form class="form-inline .d-none .d-sm-block" action="/search" method="GET">
                    <input class="form-control mr-sm-2" type="search" placeholder="Search" name="search" aria-label="Search">
                    <button type="submit" class="btn btn-link p-0" style="text-decoration:none;">
                        <i class="fa-solid fa-magnifying-glass" style="color: #ffffff;"></i>
                    </button>
                </form>
                <div class="nav-right-btn">

                    <a href="/product/wishlist" class="nav-wishlist"><i class="fa-solid fa-heart"
                            style="color: #ffffff;"></i>
                    </a>

                    <a href="/user/cart" class="nav-cart" id="navCart">
                        <i class="fa-solid fa-cart-shopping" style="color: #ffffff;"></i>
                        <% if(!user || user === " " || user === undefined){ %>
                            <input type="text" id="cartCountInput" class="cart-count" readonly value=0>
                        <% } else { %>
                            <input type="text" id="cartCountInput" class="cart-count" readonly value="<%= user?.cart?.length %>">
                        <% } %>
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">

                        <!-- button icon -->
                        <i class="fa-solid fa-bars" style="color: #eceff4;"></i>

                    </button>
                </div>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item product-dropdown">
                            <a class="nav-link product-dropdown-btn" href="#our-products">Our Products 
                                <i class="fa-solid fa-caret-right" style="color: #ffffff;"></i></a>
                            <ul class="drop-down">
                                <a class="necklace">
                                    <li>
                                        <span>Spare Parts</span>
                                        <i class="fa-solid fa-caret-right" style="color: #ffffff;"></i>
                                    </li>

                                </a>

                                <!-- Mobile: Spare Parts Sub-menu -->
                                <ul class="sub-drop drop-down-necklace">
                                    <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                                        <% brands.forEach((brand)=> { %>
                                            <a href="/product/?category=spare_parts&brand=<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>"><li><%= brand.name %></li></a>
                                        <% }) %>
                                    <% } %>
                                </ul>
                                
                                <!-- 2. Accessories Category (Mobile) -->
                                <a class="earring">
                                    <li>
                                        <span>Accessories</span>
                                        <i class="fa-solid fa-caret-right" style="color: #ffffff;"></i>

                                    </li>
                                </a>

                                <!-- Mobile: Accessories Sub-menu -->
                                <ul class="sub-drop drop-down-earring">
                                    <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                                        <% brands.forEach((brand)=> { %>
                                            <a href="/product/?category=accessories&brand=<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>"><li><%= brand.name %></li></a>
                                        <% }) %>
                                    <% } %>
                                </ul>

                                <!-- 3. Tools Category (Mobile) -->
                                <a class="ring" href="/product/?category=tools">
                                    <li>
                                        <span>Tools</span>
                                        <i class="fa-solid fa-caret-right" style="color: #ffffff;"></i>
                                    </li>
                                </a>

                                <!-- Extra to keep nav functional -->
                                <a class="bracelet" style="display: none; visibility: hidden;">
                                    <li>
                                        <span>New option</span>
                                        <i class="fa-solid fa-caret-right" style="color: #ffffff;"></i>
                                    </li>
                                </a>

                            </ul>

                            <!-- Desktop -->
                            <ul class="sub-drop drop-down-necklace d-none d-lg-block">
                                <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                                        <% brands.forEach((brand)=> { %>
                                            <a href="/product/?category=spare_parts&brand=<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>"><li><%= brand.name %></li></a>
                                        <% }) %>
                                    <% } %>
                            </ul>

                             <!-- Desktop: Accessories Flyout Menu -->
                            <ul class="sub-drop drop-down-earring d-none d-lg-block">
                                <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                                        <% brands.forEach((brand)=> { %>
                                            <a href="/product/?category=accessories&brand=<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>"><li><%= brand.name %></li></a>
                                        <% }) %>
                                    <% } %>
                            </ul>

                            <ul class="sub-drop drop-down-ring d-none d-lg-block">
                                <a href="/product/?category=tools"><li>Tools</li></a>
                            </ul>

                            <!-- Extra Part to keep nav functional -->
                            <ul class="sub-drop drop-down-bracelet d-none d-lg-block">
                                <a href="/product/?category=Bracelets"><h6>New Option</h6></a>
                            </ul>

                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/sale">Sale</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/product/wishlist">Wishlist</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/user/cart">Cart</a>
                        </li>
                        <li class="nav-item">
                                <% if (user && (user.firstname !== " " && user !== " ")) { %>
                                    <a class="nav-link" href="/viewAccount"><%= user.firstname %></a>
                                <% } else { %>
                                    <a class="nav-link" href="/myacc">My Account</a>    
                                <% } %>
                        </li>
                        <li class="nav-item">
                            <% if(user && user.role == "admin") { %>
                                <a class="nav-link" href="/admin">Admin</a>
                            <% } %>
                        </li>
                    </ul>
                </div>
                <form class="form-mob form-inline" action="/search" method="GET">
                    <input class="form-control mr-sm-2" type="search" placeholder="Search" name="search" aria-label="Search">
                    <button type="submit" class="btn btn-link p-0" style="text-decoration:none;">
                        <i class="fa-solid fa-magnifying-glass" style="color: #ffffff;"></i>
                    </button>
                </form>
            </div>
        </nav>
    </section>
