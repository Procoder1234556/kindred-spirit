<!DOCTYPE html>
<html>

<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>

    <title><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : 'Sahii – Buy Mobile Spare Parts Online India' %></title>
    <meta name="description" content="<%= typeof pageDesc !== 'undefined' && pageDesc ? pageDesc : 'Sahii is an online platform providing high-quality repair parts for mobile phones and tablets across multiple brands and models. From screens and batteries to charging ports and components, Sahii makes device repair easy, reliable, and affordable.' %>">
    <meta name="keywords" content="<%= typeof pageKeywords !== 'undefined' && pageKeywords ? pageKeywords : 'mobile repair parts, phone spare parts, tablet repair parts, smartphone replacement parts, mobile screen replacement, phone battery replacement, repair components online, Sahii repair parts' %>">
    <meta name="author" content="Sahii - Mobile & Tablet Repair Parts Platform">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : 'https://sahii.in' %>">

    <meta property="og:site_name" content="Sahii">
    <meta property="og:type" content="<%= typeof ogType !== 'undefined' && ogType ? ogType : 'website' %>">
    <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : 'Sahii – Buy Mobile Spare Parts Online India' %>">
    <meta property="og:description" content="<%= typeof pageDesc !== 'undefined' && pageDesc ? pageDesc : 'Buy genuine OEM-grade mobile spare parts online at Sahii. Screens, batteries, charging ports and more for all brands.' %>">
    <meta property="og:image" content="<%= typeof ogImage !== 'undefined' && ogImage ? ogImage : 'https://sahii.in/images/logo/logo.png' %>">
    <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : 'https://sahii.in' %>">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : 'Sahii – Buy Mobile Spare Parts Online India' %>">
    <meta name="twitter:description" content="<%= typeof pageDesc !== 'undefined' && pageDesc ? pageDesc : 'Buy genuine OEM-grade mobile spare parts online at Sahii.' %>">
    <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' && ogImage ? ogImage : 'https://sahii.in/images/logo/logo.png' %>">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/styles/style.css">
    <link rel="icon" sizes="192x192" href="/images/logo/sahii logo.png">
    <link rel="icon" type="image/jpg" sizes="512x512" href="/images/logo/sahii logo.png">
    <link rel="icon" type="image/jpg" sizes="16x16" href="/images/logo/sahii logo.png">

    <link rel="preconnect" href="/muli" crossorigin>
    <link rel="stylesheet" href="/themify-icons-font/themify-icons.css">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel='stylesheet' type='text/css' media='screen' href='/css/main.css?v=3'>
    <link rel='stylesheet' type='text/css' href='/css/nav-improvements.css?v=3'>
    <link rel="stylesheet" type='text/css' href="/css/responsive.css?v=3">
    <link rel='stylesheet' type='text/css' href='/css/testimonial.css?v=3'>
    <link rel='stylesheet' type='text/css' href='/css/sahii-ux.css?v=3'>

    <script src="https://kit.fontawesome.com/86c248a3a6.js" crossorigin="anonymous"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
</head>

<body>

    <section id="header">

        <!-- Announcement Bar -->
        <div class="sahii-topbar">
            <div class="sahii-topbar-track">
                <span class="announcement-bar"></span>
            </div>
        </div>

        <!-- Main Navbar -->
        <nav class="navbar navbar-expand-lg sahii-navbar fixed-top">
            <div class="container-fluid sahii-navbar-inner px-3 px-lg-4">

                <!-- Logo -->
                <a class="navbar-brand sahii-brand" href="/">
                    <img src="/images/logo/logo.png" class="brand-logo" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                    <span class="brand-wordmark" style="display:none;">SAHII</span>
                </a>

                <!-- Desktop Search Bar -->
                <form class="sahii-search d-none d-lg-flex" action="/search" method="GET" id="searchFormDesktop">
                    <i class="fa-solid fa-magnifying-glass sahii-search-icon"></i>
                    <input class="sahii-search-input" type="search" placeholder="Search for mobile parts, brands, models…" name="search" autocomplete="off" id="searchInputDesktop">
                    <button type="submit" class="sahii-search-btn">Search</button>
                    <div id="suggestionsDesktop" class="search-suggestions d-none"></div>
                </form>

                <!-- Right Icons -->
                <div class="sahii-nav-actions d-flex align-items-center gap-2">
                    <a href="/product/wishlist" class="sahii-icon-btn d-none d-lg-flex" title="Wishlist">
                        <i class="fa-solid fa-heart"></i>
                    </a>
                    <a href="/user/cart" class="sahii-icon-btn sahii-cart-btn" id="navCart" title="Cart">
                        <i class="fa-solid fa-cart-shopping"></i>
                        <% if(!user || user === " " || user === undefined){ %>
                            <span class="sahii-cart-badge" id="cartCountInput">0</span>
                        <% } else { %>
                            <span class="sahii-cart-badge" id="cartCountInput"><%= user?.cart?.length || 0 %></span>
                        <% } %>
                    </a>
                    <% if (user && (user.firstname !== " " && user !== " ")) { %>
                        <a href="/viewAccount" class="sahii-icon-btn d-none d-lg-flex" title="My Account">
                            <i class="fa-solid fa-user"></i>
                        </a>
                    <% } else { %>
                        <a href="/myacc" class="sahii-icon-btn d-none d-lg-flex" title="Login">
                            <i class="fa-solid fa-user"></i>
                        </a>
                    <% } %>
                    <button class="sahii-hamburger navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                </div>
            </div>

            <!-- Desktop Nav Links Row -->
            <div class="sahii-navbar-links d-none d-lg-flex">
                <div class="container-fluid px-4">
                    <ul class="navbar-nav sahii-desktop-nav">

                        <li class="nav-item product-dropdown">
                            <a class="nav-link product-dropdown-btn" href="#our-products">
                                Our Products <i class="fa-solid fa-chevron-down ms-1" style="font-size:.75rem;"></i>
                            </a>
                            <ul class="drop-down">
                                <a class="cat-spare-parts">
                                    <li>
                                        <span>Spare Parts</span>
                                        <i class="fa-solid fa-caret-right"></i>
                                    </li>
                                </a>
                                <ul class="sub-drop flyout-spare-parts">
                                    <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                                        <% brands.forEach((brand)=> { %>
                                            <a href="/product/?category=spare_parts&brand=<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>"><li><%= brand.name %></li></a>
                                        <% }) %>
                                    <% } %>
                                </ul>
                                <a class="cat-accessories">
                                    <li>
                                        <span>Accessories</span>
                                        <i class="fa-solid fa-caret-right"></i>
                                    </li>
                                </a>
                                <ul class="sub-drop flyout-accessories">
                                    <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                                        <% brands.forEach((brand)=> { %>
                                            <a href="/product/?category=accessories&brand=<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>"><li><%= brand.name %></li></a>
                                        <% }) %>
                                    <% } %>
                                </ul>
                                <a class="cat-tools" href="/product/?category=tools">
                                    <li>
                                        <span>Tools</span>
                                        <i class="fa-solid fa-caret-right"></i>
                                    </li>
                                </a>
                                <a class="cat-extra" style="display:none; visibility:hidden;">
                                    <li><span>New option</span><i class="fa-solid fa-caret-right"></i></li>
                                </a>
                            </ul>

                            <ul class="sub-drop flyout-spare-parts d-none d-lg-block">
                                <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                                    <% brands.forEach((brand)=> { %>
                                        <a href="/product/?category=spare_parts&brand=<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>"><li><%= brand.name %></li></a>
                                    <% }) %>
                                <% } %>
                            </ul>
                            <ul class="sub-drop flyout-accessories d-none d-lg-block">
                                <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                                    <% brands.forEach((brand)=> { %>
                                        <a href="/product/?category=accessories&brand=<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>"><li><%= brand.name %></li></a>
                                    <% }) %>
                                <% } %>
                            </ul>
                            <ul class="sub-drop flyout-tools d-none d-lg-block">
                                <a href="/product/?category=tools"><li>Tools</li></a>
                            </ul>
                            <ul class="sub-drop drop-down-extra d-none d-lg-block">
                                <a href="/product"><h6>View All Products</h6></a>
                            </ul>
                        </li>

                        <li class="nav-item"><a class="nav-link" href="/sale">Sale</a></li>
                        <li class="nav-item"><a class="nav-link" href="/blog">Blog</a></li>
                        <li class="nav-item"><a class="nav-link" href="/product/wishlist">Wishlist</a></li>
                        <li class="nav-item"><a class="nav-link" href="/user/cart">Cart</a></li>
                        <li class="nav-item">
                            <% if (user && (user.firstname !== " " && user !== " ")) { %>
                                <a class="nav-link" href="/viewAccount"><%= user.firstname %></a>
                            <% } else { %>
                                <a class="nav-link" href="/myacc">My Account</a>
                            <% } %>
                        </li>
                        <% if(user && user.role == "admin") { %>
                            <li class="nav-item"><a class="nav-link sahii-admin-link" href="/admin">Admin</a></li>
                        <% } %>
                    </ul>
                </div>
            </div>

            <!-- Mobile Collapse Menu -->
            <div class="collapse navbar-collapse sahii-mobile-menu" id="navbarNav">
                <!-- Mobile Search -->
                <form class="sahii-search sahii-search-mobile" action="/search" method="GET" id="searchFormMobile">
                    <i class="fa-solid fa-magnifying-glass sahii-search-icon"></i>
                    <input class="sahii-search-input" type="search" placeholder="Search for parts…" name="search" autocomplete="off" id="searchInputMobile">
                    <button type="submit" class="sahii-search-btn">Go</button>
                    <div id="suggestionsMobile" class="search-suggestions d-none"></div>
                </form>

                <!-- Mobile Nav Links -->
                <ul class="navbar-nav sahii-mobile-nav">
                    <li class="nav-item product-dropdown">
                        <a class="nav-link product-dropdown-btn" href="#our-products">
                            Our Products <i class="fa-solid fa-caret-right"></i>
                        </a>
                        <ul class="drop-down">
                            <a class="cat-spare-parts">
                                <li><span>Spare Parts</span><i class="fa-solid fa-caret-right"></i></li>
                            </a>
                            <ul class="sub-drop flyout-spare-parts">
                                <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                                    <% brands.forEach((brand)=> { %>
                                        <a href="/product/?category=spare_parts&brand=<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>"><li><%= brand.name %></li></a>
                                    <% }) %>
                                <% } %>
                            </ul>
                            <a class="cat-accessories">
                                <li><span>Accessories</span><i class="fa-solid fa-caret-right"></i></li>
                            </a>
                            <ul class="sub-drop flyout-accessories">
                                <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                                    <% brands.forEach((brand)=> { %>
                                        <a href="/product/?category=accessories&brand=<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>"><li><%= brand.name %></li></a>
                                    <% }) %>
                                <% } %>
                            </ul>
                            <a class="cat-tools" href="/product/?category=tools">
                                <li><span>Tools</span><i class="fa-solid fa-caret-right"></i></li>
                            </a>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/sale">Sale</a></li>
                    <li class="nav-item"><a class="nav-link" href="/blog">Blog</a></li>
                    <li class="nav-item"><a class="nav-link" href="/product/wishlist"><i class="fa-solid fa-heart me-2"></i>Wishlist</a></li>
                    <li class="nav-item"><a class="nav-link" href="/user/cart"><i class="fa-solid fa-cart-shopping me-2"></i>Cart</a></li>
                    <li class="nav-item">
                        <% if (user && (user.firstname !== " " && user !== " ")) { %>
                            <a class="nav-link" href="/viewAccount"><i class="fa-solid fa-user me-2"></i><%= user.firstname %></a>
                        <% } else { %>
                            <a class="nav-link" href="/myacc"><i class="fa-solid fa-user me-2"></i>My Account</a>
                        <% } %>
                    </li>
                    <% if(user && user.role == "admin") { %>
                        <li class="nav-item"><a class="nav-link sahii-admin-link" href="/admin">Admin</a></li>
                    <% } %>
                </ul>
            </div>
        </nav>
    </section>
