<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - User Activity</title>
    <link href="/styles/style.css" rel="stylesheet">
    <style>
        .admin-dashboard { padding: 2rem; max-width: 1200px; margin: 0 auto; color: #333; }
        .summary-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
        .card { background: #fff; padding: 1.5rem; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .card h3 { margin-top: 0; font-size: 1.1rem; color: #666; }
        .card p { font-size: 2rem; font-weight: bold; margin: 0.5rem 0 0 0; color: #2c3e50; }
        .filter-section { margin-bottom: 1.5rem; }
        table { width: 100%; border-collapse: collapse; background: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.1); border-radius: 8px; overflow: hidden; }
        th, td { padding: 1rem; text-align: left; border-bottom: 1px solid #eee; }
        th { background: #f8f9fa; font-weight: 600; color: #444; }
        tr:hover { background: #fdfdfd; }
        .event-badge { padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.85rem; font-weight: 600; }
        .badge-page { background: #e3f2fd; color: #1976d2; }
        .badge-product { background: #e8f5e9; color: #2e7d32; }
        .badge-cart { background: #fff3e0; color: #f57c00; }
    </style>
</head>
<body style="background: #f4f6f8;">

<div class="admin-dashboard">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1 style="margin:0;">User Activity Dashboard</h1>
        <a href="/admin" style="text-decoration: none; color: #1976d2; font-weight: 600;">&larr; Back to Admin</a>
    </div>

    <!-- Analytics Summary -->
    <div class="summary-cards">
        <div class="card">
            <h3>Page Views (Today)</h3>
            <p><%= pageViewsToday || 0 %></p>
        </div>
        <div class="card">
            <h3>Add to Carts (Today)</h3>
            <p><%= addToCartsToday || 0 %></p>
        </div>
        <div class="card" style="grid-column: span 2;">
            <h3>Top Trending Products</h3>
            <ul style="margin: 0.5rem 0 0 0; padding-left: 1.2rem;">
                <% if(topProducts && topProducts.length > 0) { %>
                    <% topProducts.forEach(p => { %>
                        <li style="margin-bottom: 0.25rem;">
                            <strong><%= p.product[0]?.title || 'Unknown' %></strong> 
                            <span style="color:#666;">(<%= p.count %> views)</span>
                        </li>
                    <% }) %>
                <% } else { %>
                    <li style="color: #666;">No product views yet.</li>
                <% } %>
            </ul>
        </div>
    </div>

    <!-- Filter System -->
    <div class="filter-section">
        <form action="/admin/activity" method="GET" style="display: flex; gap: 1rem; align-items: center;">
            <label for="type" style="font-weight: 600;">Filter Events:</label>
            <select name="type" id="type" onchange="this.form.submit()" style="padding: 0.5rem; border-radius: 4px; border: 1px solid #ccc;">
                <option value="">All Events</option>
                <option value="page_view">Page Views</option>
                <option value="product_view">Product Views</option>
                <option value="add_to_cart">Add To Carts</option>
            </select>
        </form>
    </div>

    <!-- History Table -->
    <table>
        <thead>
            <tr>
                <th>Event Type</th>
                <th>User / Guest</th>
                <th>Context (URL / Product)</th>
                <th>Time (Local)</th>
            </tr>
        </thead>
        <tbody>
            <% if(events && events.length > 0) { %>
                <% events.forEach(event => { %>
                    <tr>
                        <td>
                            <span class="event-badge 
                                <%= event.eventType === 'page_view' ? 'badge-page' 
                                  : event.eventType === 'product_view' ? 'badge-product' 
                                  : 'badge-cart' %>">
                                <%= event.eventType.toUpperCase().replace(/_/g, ' ') %>
                            </span>
                        </td>
                        <td>
                            <%= event.userId ? event.userId.email : 'Guest / Anonymous' %>
                        </td>
                        <td>
                            <% if (event.eventType === 'page_view') { %>
                                <a href="<%= event.url %>" target="_blank" style="color:#1976d2; text-decoration:none;"><%= event.url %></a>
                            <% } else if (event.eventType === 'product_view') { %>
                                Product: <strong><%= event.productId ? event.productId.title : 'Deleted Product' %></strong>
                            <% } else if (event.eventType === 'add_to_cart') { %>
                                Added: <strong><%= event.productId ? event.productId.title : 'Deleted Product' %></strong> <span style="color:#666;">(Qty: <%= event.quantity || 1 %>)</span>
                            <% } %>
                        </td>
                        <td>
                            <%= new Date(event.createdAt).toLocaleString() %>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="4" style="text-align: center; color: #666; padding: 2rem;">No recent events found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<script>
    // small script to preserve dropdown selection
    const urlParams = new URLSearchParams(window.location.search);
    const type = urlParams.get('type');
    if(type) {
        document.getElementById('type').value = type;
    }
</script>

</body>
</html>
